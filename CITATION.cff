date-released: "2026-07-06"
license: MIT
url: "https://github.com/Rob-McCormack/collapse3"
repository-code: "https://github.com/Rob-McCormack/collapse3"
keywords:
  - game-solving
  - evaluation
  - regret
  - state-representation
  - reinforcement-learning
